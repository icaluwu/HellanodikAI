# HellanodikAI — Environment Variables Template
# Salin file ini ke .env dan isi nilainya. Jangan commit .env ke git!

# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------
# Pilihan: GoToCompany/llama3-8b-cpt-sahabatai-v1-instruct  (default)
#          Qwen/Qwen2.5-7B-Instruct                          (fallback)
MODEL_ID=GoToCompany/llama3-8b-cpt-sahabatai-v1-instruct

# Nama repo HuggingFace untuk model fine-tuned (wajib prefix "Llama-")
HF_FINETUNED_REPO=Llama-HellanodikAI-8B

# HuggingFace access token (untuk download model gated & push ke Hub)
HF_TOKEN=hf_your_token_here

# ---------------------------------------------------------------------------
# Local Inference (GGUF)
# ---------------------------------------------------------------------------
# Path absolut ke file GGUF setelah download & konversi
GGUF_MODEL_PATH=./models/hellanodikai.gguf

# Quantization: Q4_K_M (direkomendasikan), Q5_K_M, Q8_0, dll.
GGUF_QUANT=Q4_K_M

# CPU threads untuk llama-cpp (sesuaikan dengan jumlah core CPU Anda)
# Ryzen 3 3200G = 4 core / 4 threads
N_THREADS=4

# Context window dalam token
N_CTX=4096

# Token maksimum per respons
MAX_NEW_TOKENS=1024

# Temperature (0.1 = deterministik/faktual, cocok untuk hukum)
TEMPERATURE=0.1

# ---------------------------------------------------------------------------
# RAG
# ---------------------------------------------------------------------------
# Top-K retrieval sebelum reranking
BM25_TOP_K=10
FAISS_TOP_K=10

# Top-K setelah reranking (masuk ke prompt)
RERANKER_TOP_K=5

# Model embedding (jangan ganti kecuali rebuild index)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Model CrossEncoder reranker
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---------------------------------------------------------------------------
# Fine-tuning (Kaggle)
# ---------------------------------------------------------------------------
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
TRAIN_EPOCHS=3
TRAIN_BATCH_SIZE=2
GRAD_ACCUM_STEPS=8
LEARNING_RATE=2e-4
MAX_SEQ_LENGTH=2048

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
GRADIO_PORT=7860
# Set ke "true" untuk mendapatkan link public (Gradio share)
GRADIO_SHARE=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
